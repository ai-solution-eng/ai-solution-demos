tests/
Dockerfile
Dockerfile.prod
.mypy_cache
.ruff_cache
.pytest_cache
**/*.pyc
**/*.pyo
**/*.pyd
# Only want app/ and scripts/ in the image
!app/
!scripts/
!pyproject.toml
!uv.lock
